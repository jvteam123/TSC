<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ProResume | Professional Resume Builder</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Sortable/1.15.0/Sortable.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Playfair+Display:wght@700;900&family=JetBrains+Mono:wght@400;700&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Outfit:wght@300;400;600;900&display=swap" rel="stylesheet">
    <style>
        :root { --theme-color: #6366f1; }
        body { font-family: 'Inter', sans-serif; background-color: #f1f5f9; -webkit-font-smoothing: antialiased; }
        
        @media print {
            @page { size: A4; margin: 0; }
            .no-print { display: none !important; }
            body { background: white !important; padding: 0 !important; margin: 0 !important; overflow: visible !important; }
            .resume-page { box-shadow: none !important; border: none !important; width: 210mm !important; min-height: 297mm !important; padding: 15mm 20mm !important; margin: 0 !important; transform: none !important; }
            * { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
        }

        .resume-page { 
            width: 210mm; 
            min-height: 297.1mm; /* Fixed overlap bug */
            background: white; 
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.15); 
            padding: 20mm; 
            transform-origin: top center; 
            transition: transform 0.2s ease;
            position: relative;
        }

        .custom-scroll::-webkit-scrollbar { width: 5px; }
        .custom-scroll::-webkit-scrollbar-track { background: transparent; }
        .custom-scroll::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }

        /* Style Presets */
        .style-1 { font-family: 'Inter', sans-serif; }
        .style-2 { font-family: 'Playfair Display', serif; }
        .style-3 { font-family: 'Outfit', sans-serif; }
        .style-4 { font-family: 'JetBrains Mono', monospace; }
        .style-5 { font-family: 'Libre Baskerville', serif; }

        .section-title { 
            color: var(--theme-color); 
            font-size: 0.75rem; 
            font-weight: 800; 
            letter-spacing: 0.35em; 
            text-transform: uppercase; 
            border-bottom: 2px solid #f1f5f9; 
            padding-bottom: 6px; 
            margin-bottom: 16px; 
            margin-top: 24px; 
        }
        
        #printModal { display: none; position: fixed; inset: 0; background: rgba(15, 23, 42, 0.85); backdrop-filter: blur(8px); z-index: 100; align-items: center; justify-content: center; }
        #printModal.active { display: flex; }

        .drag-handle { cursor: grab; color: #cbd5e1; }
        .drag-handle:active { cursor: grabbing; }
        .sortable-ghost { opacity: 0.3; background: #eef2ff !important; border: 2px dashed var(--theme-color) !important; }
        .style-btn.active { border-color: var(--theme-color); background: #eef2ff; color: var(--theme-color); }

        /* Floating Tips */
        .floating-tip { animation: slideIn 0.5s ease-out; }
        @keyframes slideIn { from { transform: translateY(-10px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }

        /* Save Indicator */
        #save-indicator { transition: opacity 0.5s ease; opacity: 0; }
        #save-indicator.visible { opacity: 1; }
    </style>
</head>
<body class="flex flex-col h-screen overflow-hidden">

    <!-- Top Navigation -->
    <nav class="bg-white border-b border-slate-200 px-8 py-3 flex justify-between items-center no-print shrink-0 z-20">
        <div class="flex items-center gap-4">
            <div class="bg-indigo-600 p-2 rounded-xl text-white shadow-lg shadow-indigo-100">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
            </div>
            <div>
                <h1 class="text-lg font-black tracking-tighter text-slate-800 uppercase leading-none">Pro<span class="text-indigo-600">Resume</span></h1>
                <div id="save-indicator" class="flex items-center gap-1.5 mt-1">
                    <div class="w-1.5 h-1.5 bg-emerald-500 rounded-full animate-pulse"></div>
                    <span class="text-[8px] font-black text-slate-400 uppercase tracking-widest">Changes Saved</span>
                </div>
            </div>
        </div>

        <div class="flex items-center gap-6">
            <!-- Style Selection -->
            <div class="flex items-center gap-2 bg-slate-50 p-1 rounded-xl border border-slate-200">
                <span class="text-[9px] font-black text-slate-400 uppercase tracking-widest px-2">Layout</span>
                <div class="flex gap-1" id="style-picker">
                    <button onclick="changeStyle(1)" class="style-btn px-2.5 py-1 rounded-lg text-[10px] font-bold border border-transparent transition-all">1</button>
                    <button onclick="changeStyle(2)" class="style-btn px-2.5 py-1 rounded-lg text-[10px] font-bold border border-transparent transition-all">2</button>
                    <button onclick="changeStyle(3)" class="style-btn px-2.5 py-1 rounded-lg text-[10px] font-bold border border-transparent transition-all">3</button>
                    <button onclick="changeStyle(4)" class="style-btn px-2.5 py-1 rounded-lg text-[10px] font-bold border border-transparent transition-all">4</button>
                    <button onclick="changeStyle(5)" class="style-btn px-2.5 py-1 rounded-lg text-[10px] font-bold border border-transparent transition-all">5</button>
                </div>
            </div>

            <!-- Theme & Actions -->
            <div class="flex items-center gap-4 border-l border-slate-200 pl-6">
                <input type="color" id="theme-color" value="#6366f1" oninput="updatePreview()" class="w-8 h-8 rounded-full cursor-pointer border-2 border-white shadow-sm overflow-hidden bg-transparent">
                
                <div class="flex gap-2">
                    <button onclick="exportJSON()" title="Backup Data" class="p-2.5 text-slate-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-xl transition-all">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                    </button>
                    <button onclick="showPrintModal()" class="bg-indigo-600 hover:bg-indigo-700 text-white px-5 py-2.5 rounded-xl font-bold text-sm transition-all flex items-center gap-2 shadow-lg shadow-indigo-100">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
                        Export PDF
                    </button>
                </div>
            </div>
        </div>
    </nav>

    <main class="flex flex-1 overflow-hidden bg-slate-50">
        <!-- Editor Sidebar -->
        <aside class="w-[480px] border-r border-slate-200 bg-white overflow-y-auto custom-scroll no-print p-8 space-y-8 pb-20 shadow-xl z-10">
            <!-- Header Group -->
            <div class="space-y-6">
                <div class="flex items-center justify-between">
                    <h2 class="text-[10px] font-black text-slate-400 uppercase tracking-[0.3em]">Personal Profile</h2>
                    <button onclick="resetData()" class="text-[9px] font-bold text-red-400 uppercase tracking-widest hover:bg-red-50 px-2 py-1 rounded-lg">Reset</button>
                </div>
                
                <!-- Avatar Upload -->
                <div class="flex items-center gap-6 p-6 bg-slate-50 rounded-3xl border border-slate-100">
                    <div class="relative group">
                        <div id="photo-preview" class="w-20 h-20 bg-white border-2 border-dashed border-slate-200 rounded-2xl flex items-center justify-center overflow-hidden transition-all group-hover:border-indigo-300">
                            <img id="profile-img" class="hidden absolute inset-0 w-full h-full object-cover">
                            <span class="text-[9px] font-black text-slate-300 uppercase">Upload</span>
                        </div>
                        <input type="file" accept="image/*" onchange="handlePhoto(this)" class="absolute inset-0 opacity-0 cursor-pointer">
                    </div>
                    <div>
                        <p class="text-[10px] font-black uppercase text-slate-800 tracking-wider">Profile Photo</p>
                        <p class="text-[9px] text-slate-400 uppercase mt-1">PNG, JPG recommended</p>
                        <button onclick="removePhoto()" class="text-[10px] font-bold text-red-500 uppercase mt-2 hover:underline">Remove</button>
                    </div>
                </div>

                <!-- Basic Fields -->
                <div class="grid grid-cols-1 gap-4">
                    <div class="space-y-1">
                        <label class="text-[9px] font-black text-slate-400 uppercase tracking-widest pl-2">Full Name</label>
                        <input type="text" id="in-name" oninput="updatePreview()" placeholder="Full Name" class="w-full px-5 py-3.5 bg-slate-50/50 border border-slate-200 rounded-xl text-sm font-semibold outline-none focus:border-indigo-500 focus:bg-white transition-all">
                    </div>
                    <div class="space-y-1">
                        <label class="text-[9px] font-black text-slate-400 uppercase tracking-widest pl-2">Job Title</label>
                        <input type="text" id="in-title" oninput="updatePreview()" placeholder="Professional Title" class="w-full px-5 py-3.5 bg-slate-50/50 border border-slate-200 rounded-xl text-sm font-semibold outline-none focus:border-indigo-500 focus:bg-white transition-all">
                    </div>
                    <div class="grid grid-cols-2 gap-4">
                        <input type="text" id="in-email" oninput="updatePreview()" placeholder="Email" class="w-full px-4 py-3.5 bg-slate-50/50 border border-slate-200 rounded-xl text-sm outline-none focus:border-indigo-500 focus:bg-white">
                        <input type="text" id="in-phone" oninput="updatePreview()" placeholder="Phone" class="w-full px-4 py-3.5 bg-slate-50/50 border border-slate-200 rounded-xl text-sm outline-none focus:border-indigo-500 focus:bg-white">
                    </div>
                    <input type="text" id="in-location" oninput="updatePreview()" placeholder="Location (City, Country)" class="w-full px-4 py-3.5 bg-slate-50/50 border border-slate-200 rounded-xl text-sm outline-none focus:border-indigo-500 focus:bg-white">
                </div>
            </div>

            <!-- Dynamic Sections -->
            <div class="space-y-6">
                <div class="flex items-center justify-between">
                    <h2 class="text-[10px] font-black text-slate-400 uppercase tracking-[0.3em]">Sections</h2>
                    <span class="text-[9px] font-bold text-slate-300 uppercase tracking-widest">Hold drag handle to reorder</span>
                </div>
                
                <div id="dynamic-sections" class="space-y-4"></div>

                <div class="bg-indigo-50/50 p-6 rounded-3xl border border-indigo-100 space-y-4">
                    <div class="grid grid-cols-2 gap-2">
                        <button onclick="addSection('Summary', 'text')" class="px-3 py-2.5 bg-white border border-slate-200 rounded-xl text-[9px] font-bold uppercase tracking-wider text-slate-600 hover:border-indigo-300 transition-all flex items-center justify-center gap-2">🎯 Summary</button>
                        <button onclick="addSection('Experience', 'list')" class="px-3 py-2.5 bg-white border border-slate-200 rounded-xl text-[9px] font-bold uppercase tracking-wider text-slate-600 hover:border-indigo-300 transition-all flex items-center justify-center gap-2">💼 Experience</button>
                        <button onclick="addSection('Education', 'list')" class="px-3 py-2.5 bg-white border border-slate-200 rounded-xl text-[9px] font-bold uppercase tracking-wider text-slate-600 hover:border-indigo-300 transition-all flex items-center justify-center gap-2">🎓 Education</button>
                        <button onclick="addSection('Skills', 'tags')" class="px-3 py-2.5 bg-white border border-slate-200 rounded-xl text-[9px] font-bold uppercase tracking-wider text-slate-600 hover:border-indigo-300 transition-all flex items-center justify-center gap-2">⚡ Skills</button>
                    </div>
                    <button onclick="addSection('Custom Block', 'text')" class="w-full py-3.5 bg-indigo-600 text-white rounded-xl text-[10px] font-black uppercase tracking-[0.2em] shadow-md hover:bg-indigo-700 transition-all">+ New Custom Section</button>
                </div>
            </div>
        </aside>

        <!-- Preview Viewport -->
        <section class="flex-1 overflow-y-auto p-12 flex flex-col items-center custom-scroll relative">
            <!-- UI Floating Tip -->
            <div id="tip-container" class="absolute top-6 right-8 z-30 no-print">
                <div class="floating-tip bg-white border border-slate-200 rounded-2xl py-2.5 px-5 shadow-2xl flex items-center gap-3 border-l-4 border-l-indigo-500">
                    <div class="bg-indigo-50 text-indigo-600 p-1 rounded-lg">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
                    </div>
                    <p id="tip-text" class="text-[9px] font-black text-slate-500 uppercase tracking-widest">Preview is exactly what you get</p>
                </div>
            </div>

            <!-- Page Canvas -->
            <div id="resume-canvas-container" class="w-full flex justify-center pb-20">
                <div id="resume-canvas" class="resume-page style-1"></div>
            </div>
        </section>
    </main>

    <!-- Export Modal -->
    <div id="printModal" class="no-print">
        <div class="bg-white p-10 rounded-[2.5rem] shadow-2xl max-w-sm w-full text-center border border-slate-100 scale-in">
            <div class="w-16 h-16 bg-indigo-50 text-indigo-600 rounded-2xl flex items-center justify-center mx-auto mb-6">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
            </div>
            <h2 class="text-2xl font-black text-slate-900 mb-2 tracking-tight">Print as PDF</h2>
            <p class="text-slate-500 text-xs mb-8 leading-relaxed">Ensure <span class="font-bold text-slate-800">Background Graphics</span> is enabled in the print settings to preserve your theme colors.</p>
            <div class="space-y-2">
                <button onclick="window.print()" class="w-full bg-indigo-600 text-white py-4 rounded-xl font-bold hover:bg-indigo-700 transition-all">Open Print Menu</button>
                <button onclick="closeModal()" class="w-full bg-slate-50 text-slate-400 py-3 rounded-xl font-bold text-sm">Cancel</button>
            </div>
        </div>
    </div>

    <script>
        const DEPLOY_VERSION = '2.3';
        
        let state = JSON.parse(localStorage.getItem('renzku_resume_v2.3')) || {
            name: 'Renzku Ebrado',
            title: 'Senior Product Designer',
            email: 'hello@renzku.com',
            phone: '+1 555 123 4567',
            location: 'Cebu, Philippines',
            theme: '#6366f1',
            styleIndex: 1,
            photo: '',
            sections: [
                { id: 'sec-1', title: 'Professional Summary', type: 'text', content: 'Design leader with 8+ years experience in high-growth startups.' },
                { id: 'sec-2', title: 'Work Experience', type: 'list', items: [{ role: 'Senior UX Designer', org: 'Creative Studio', date: '2020 - Present', loc: 'New York', desc: 'Leading design systems for Fortune 500 clients.' }] },
                { id: 'sec-3', title: 'Core Skills', type: 'tags', content: 'Figma, Tailwind CSS, JavaScript, Product Strategy' }
            ]
        };

        const tips = [
            "Preview is exactly what you get",
            "Use A4 size for the best print results",
            "Hold & drag handles to reorder sections",
            "Click on titles to rename sections",
            "Export JSON for easy data backup"
        ];
        let tipIdx = 0;

        function saveState() {
            localStorage.setItem('renzku_resume_v2.3', JSON.stringify(state));
            const indicator = document.getElementById('save-indicator');
            indicator.classList.add('visible');
            setTimeout(() => indicator.classList.remove('visible'), 2000);
        }

        window.onload = () => {
            initInputs(); 
            renderEditor(); 
            updatePreview(); 
            initSortable();
            startTipCycle();
            scalePreview();
            window.addEventListener('resize', scalePreview);
        };

        function startTipCycle() {
            setInterval(() => {
                tipIdx = (tipIdx + 1) % tips.length;
                const el = document.getElementById('tip-text');
                el.style.opacity = 0;
                setTimeout(() => {
                    el.textContent = tips[tipIdx];
                    el.style.opacity = 1;
                }, 300);
            }, 6000);
        }

        function initInputs() {
            document.getElementById('in-name').value = state.name;
            document.getElementById('in-title').value = state.title;
            document.getElementById('in-email').value = state.email;
            document.getElementById('in-phone').value = state.phone;
            document.getElementById('in-location').value = state.location || '';
            document.getElementById('theme-color').value = state.theme;
            updateStyleButtons();
            if (state.photo) {
                document.getElementById('profile-img').src = state.photo;
                document.getElementById('profile-img').classList.remove('hidden');
            }
        }

        function initSortable() {
            new Sortable(document.getElementById('dynamic-sections'), {
                handle: '.drag-handle',
                animation: 250,
                ghostClass: 'sortable-ghost',
                onEnd: function () {
                    const ids = Array.from(document.getElementById('dynamic-sections').children).map(c => c.dataset.id);
                    state.sections = ids.map(id => state.sections.find(s => s.id === id));
                    saveState();
                    updatePreview();
                }
            });
        }

        function changeStyle(index) {
            state.styleIndex = index;
            updateStyleButtons(); 
            updatePreview(); 
            saveState();
        }

        function updateStyleButtons() {
            document.querySelectorAll('.style-btn').forEach((btn, idx) => {
                btn.classList.toggle('active', (idx + 1) === state.styleIndex);
            });
            document.getElementById('resume-canvas').className = `resume-page style-${state.styleIndex}`;
        }

        function handlePhoto(input) {
            if (input.files?.[0]) {
                const reader = new FileReader();
                reader.onload = (e) => {
                    state.photo = e.target.result;
                    document.getElementById('profile-img').src = state.photo;
                    document.getElementById('profile-img').classList.remove('hidden');
                    saveState(); updatePreview();
                };
                reader.readAsDataURL(input.files[0]);
            }
        }

        function removePhoto() {
            state.photo = ''; 
            document.getElementById('profile-img').classList.add('hidden');
            saveState(); updatePreview();
        }

        function addSection(title, type) {
            const id = 'sec-' + Date.now();
            let newSec = { id, title, type };
            if (type === 'text' || type === 'tags') newSec.content = '';
            else newSec.items = [{ role: '', org: '', date: '', loc: '', desc: '' }];
            state.sections.push(newSec);
            renderEditor(); updatePreview(); saveState();
        }

        function updateSection(id, key, value) {
            const sec = state.sections.find(s => s.id === id);
            if (sec) { sec[key] = value; saveState(); updatePreview(); }
        }

        function updateListItem(sid, idx, key, value) {
            const sec = state.sections.find(s => s.id === sid);
            if (sec && sec.items[idx]) {
                sec.items[idx][key] = value;
                saveState(); updatePreview();
            }
        }

        function addListItem(sid) {
            state.sections.find(s => s.id === sid).items.push({ role: '', org: '', date: '', loc: '', desc: '' });
            renderEditor(); saveState();
        }

        function removeListItem(sid, idx) {
            state.sections.find(s => s.id === sid).items.splice(idx, 1);
            renderEditor(); updatePreview(); saveState();
        }

        function removeSection(id) {
            if (confirm("Delete this entire section?")) {
                state.sections = state.sections.filter(s => s.id !== id);
                renderEditor(); updatePreview(); saveState();
            }
        }

        function renderEditor() {
            const container = document.getElementById('dynamic-sections');
            container.innerHTML = state.sections.map(s => `
                <div class="p-6 bg-white rounded-3xl border border-slate-200 relative group" data-id="${s.id}">
                    <div class="flex justify-between items-center mb-4">
                        <div class="flex items-center gap-2 flex-1">
                            <div class="drag-handle p-2 -ml-2 text-slate-300 hover:text-indigo-400 cursor-grab transition-colors">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><circle cx="9" cy="5" r="1"/><circle cx="9" cy="12" r="1"/><circle cx="9" cy="19" r="1"/><circle cx="15" cy="5" r="1"/><circle cx="15" cy="12" r="1"/><circle cx="15" cy="19" r="1"/></svg>
                            </div>
                            <div class="relative flex items-center w-full">
                                <input type="text" value="${s.title}" oninput="updateSection('${s.id}', 'title', this.value)" class="font-black text-[10px] uppercase tracking-[0.2em] outline-none bg-transparent w-full text-slate-800">
                                <div class="absolute right-2 opacity-10 pointer-events-none">
                                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                </div>
                            </div>
                        </div>
                        <button onclick="removeSection('${s.id}')" class="text-slate-200 hover:text-red-400 font-bold transition-colors">✕</button>
                    </div>
                    ${s.type === 'text' || s.type === 'tags' ? `
                        <textarea oninput="updateSection('${s.id}', 'content', this.value)" placeholder="${s.type === 'tags' ? 'Separated by commas...' : 'Summarize your achievements...'}" class="w-full p-4 text-sm bg-slate-50 rounded-xl h-28 outline-none border border-transparent focus:border-indigo-100 transition-all font-medium">${s.content || ''}</textarea>
                    ` : `
                        <div class="space-y-4">
                            ${s.items.map((item, idx) => `
                                <div class="p-4 bg-slate-50/50 rounded-2xl border border-slate-100 relative group/item">
                                    <button onclick="removeListItem('${s.id}', ${idx})" class="absolute top-2 right-2 opacity-0 group-hover/item:opacity-100 text-[10px] text-red-400 hover:underline">Remove</button>
                                    <div class="grid grid-cols-2 gap-3 mb-2">
                                        <input type="text" placeholder="Title/Role" value="${item.role || ''}" oninput="updateListItem('${s.id}', ${idx}, 'role', this.value)" class="p-2 bg-white rounded-lg text-[11px] font-bold outline-none border border-slate-200 focus:border-indigo-200">
                                        <input type="text" placeholder="Company/Org" value="${item.org || ''}" oninput="updateListItem('${s.id}', ${idx}, 'org', this.value)" class="p-2 bg-white rounded-lg text-[11px] font-bold outline-none border border-slate-200 focus:border-indigo-200">
                                        <input type="text" placeholder="Timeline (e.g. 2020 - 2023)" value="${item.date}" oninput="updateListItem('${s.id}', ${idx}, 'date', this.value)" class="p-2 bg-white rounded-lg text-[11px] outline-none border border-slate-200 focus:border-indigo-200">
                                        <input type="text" placeholder="Location" value="${item.loc}" oninput="updateListItem('${s.id}', ${idx}, 'loc', this.value)" class="p-2 bg-white rounded-lg text-[11px] outline-none border border-slate-200 focus:border-indigo-200">
                                    </div>
                                    <textarea placeholder="Bullet points of achievements..." oninput="updateListItem('${s.id}', ${idx}, 'desc', this.value)" class="w-full p-3 bg-white rounded-lg text-[11px] outline-none border border-slate-200 focus:border-indigo-200 h-20">${item.desc}</textarea>
                                </div>
                            `).join('')}
                            <button onclick="addListItem('${s.id}')" class="w-full py-3 border-2 border-dashed border-slate-100 text-slate-300 rounded-xl text-[9px] font-black uppercase tracking-widest hover:border-indigo-100 hover:text-indigo-400 transition-all">+ Add Entry</button>
                        </div>
                    `}
                </div>
            `).join('');
        }

        function updatePreview() {
            state.name = document.getElementById('in-name').value;
            state.title = document.getElementById('in-title').value;
            state.email = document.getElementById('in-email').value;
            state.phone = document.getElementById('in-phone').value;
            state.location = document.getElementById('in-location').value;
            state.theme = document.getElementById('theme-color').value;
            document.documentElement.style.setProperty('--theme-color', state.theme);
            
            const canvas = document.getElementById('resume-canvas');
            let html = `
                <header class="flex ${state.styleIndex === 3 ? 'flex-col items-center text-center' : 'justify-between items-start'} gap-8 mb-10">
                    <div class="flex-1">
                        <h1 class="text-6xl font-black tracking-tighter leading-[0.8] mb-4 text-slate-900 uppercase">${state.name || "NAME"}</h1>
                        <p class="text-xl font-bold tracking-[0.3em] uppercase" style="color: ${state.theme}">${state.title || "TITLE"}</p>
                        <div class="flex flex-wrap ${state.styleIndex === 3 ? 'justify-center' : ''} gap-x-6 gap-y-2 text-[10px] font-black text-slate-400 uppercase tracking-widest mt-8">
                            <span class="flex items-center gap-1.5"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>${state.email || 'Email'}</span>
                            <span class="flex items-center gap-1.5"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>${state.phone || 'Phone'}</span>
                            <span class="flex items-center gap-1.5"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>${state.location || 'Location'}</span>
                        </div>
                    </div>
                    ${state.photo ? `<img src="${state.photo}" class="w-28 h-28 object-cover rounded-[2rem] shadow-xl border-4 border-white">` : ''}
                </header>
                <div class="space-y-4">
            `;

            state.sections.forEach(s => {
                let contentHtml = '';
                if (s.type === 'text' && s.content) {
                    contentHtml = `<p class="text-[11.5px] leading-relaxed text-slate-600 whitespace-pre-wrap">${s.content}</p>`;
                } else if (s.type === 'tags' && s.content) {
                    contentHtml = `<div class="flex flex-wrap gap-2">${s.content.split(',').map(t => `<span class="px-3 py-1 bg-slate-50 border border-slate-100 rounded-md text-[9px] font-bold uppercase tracking-wider text-slate-500">${t.trim()}</span>`).join('')}</div>`;
                } else if (s.type === 'list' && s.items) {
                    contentHtml = s.items.map(i => `
                        <div class="mb-5">
                            <div class="flex justify-between font-bold text-slate-900 text-sm">
                                <span>${i.role || ''}</span>
                                <span class="text-[10px] text-slate-300 uppercase tracking-widest">${i.date}</span>
                            </div>
                            <div class="flex justify-between text-[10px] font-black uppercase tracking-widest mb-1.5" style="color: ${state.theme}">
                                <span>${i.org || ''}</span>
                                <span class="text-slate-300 italic font-medium capitalize tracking-normal">${i.loc}</span>
                            </div>
                            <p class="text-[11px] text-slate-500 leading-relaxed">${i.desc}</p>
                        </div>
                    `).join('');
                }
                if (contentHtml) html += `<section><div class="section-title">${s.title}</div>${contentHtml}</section>`;
            });

            canvas.innerHTML = html + `</div>`;
            saveState();
        }

        function scalePreview() {
            const container = document.getElementById('resume-canvas-container');
            const canvas = document.getElementById('resume-canvas');
            if (!container || !canvas) return;
            const containerWidth = container.offsetWidth;
            const scale = (containerWidth - 80) / 794; 
            canvas.style.transform = scale < 1 ? `scale(${scale})` : `scale(1)`;
        }

        function exportJSON() {
            const dataStr = "data:text/json;charset=utf-8," + encodeURIComponent(JSON.stringify(state));
            const downloadAnchorNode = document.createElement('a');
            downloadAnchorNode.setAttribute("href", dataStr);
            downloadAnchorNode.setAttribute("download", `resume_backup_${new Date().toISOString().split('T')[0]}.json`);
            document.body.appendChild(downloadAnchorNode);
            downloadAnchorNode.click();
            downloadAnchorNode.remove();
        }

        function resetData() {
            if(confirm("This will permanently delete all content. Continue?")) {
                localStorage.removeItem('renzku_resume_v2.3');
                location.reload();
            }
        }

        function showPrintModal() { document.getElementById('printModal').classList.add('active'); }
        function closeModal() { document.getElementById('printModal').classList.remove('active'); }
    </script>
</body>
</html>
